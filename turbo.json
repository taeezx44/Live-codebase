{
  "$schema": "https://turbo.build/schema.json",

  "ui": "tui",

  "pipeline": {

    // ── build ──────────────────────────────────────────────────
    // Packages must build after their dependencies build.
    // ^build means "build all packages this one depends on first".
    "build": {
      "dependsOn": ["^build"],
      "inputs":    ["src/**", "tsconfig.json", "package.json"],
      "outputs":   ["dist/**", ".next/**", "!.next/cache/**"]
    },

    // ── dev ────────────────────────────────────────────────────
    // Persistent processes (never exit).
    // cache: false — always restart, never serve cached output.
    "dev": {
      "dependsOn":  ["^build"],
      "persistent": true,
      "cache":      false
    },

    // ── test ───────────────────────────────────────────────────
    "test": {
      "dependsOn": ["^build"],
      "inputs":    ["src/**", "vitest.config.ts", "package.json"],
      "outputs":   ["coverage/**"]
    },

    // ── typecheck ──────────────────────────────────────────────
    "typecheck": {
      "dependsOn": ["^build"],
      "inputs":    ["src/**", "tsconfig.json"]
    },

    // ── lint ───────────────────────────────────────────────────
    // No dependsOn — linting is independent of build order.
    "lint": {
      "inputs": ["src/**", "biome.json"]
    },

    // ── clean ──────────────────────────────────────────────────
    "clean": {
      "cache": false
    },

    // ── db:migrate ──────────────────────────────────────────────
    "db:migrate": {
      "cache": false
    }
  },

  // These env vars, when changed, bust the Turbo build cache
  // for all packages. Add any env var that affects build output.
  "globalEnv": [
    "NODE_ENV",
    "DATABASE_URL",
    "NEO4J_URI",
    "NEO4J_USER",
    "NEO4J_PASSWORD",
    "REDIS_URL",
    "PORT",
    "NEXT_PUBLIC_API_URL",
    "NEXT_PUBLIC_WS_URL"
  ]
}
