{
  "name": "@codevis/analysis-engine",
  "version": "1.0.0",
  "description": "tree-sitter AST parser + Neo4j writer",
  "main": "./dist/engine.js",
  "types": "./dist/engine.d.ts",
  "scripts": {
    "build":     "tsc -p tsconfig.json",
    "dev":       "tsc -p tsconfig.json --watch",
    "test":      "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "neo4j-driver":          "^5.20.0",
    "tree-sitter":           "^0.21.0",
    "tree-sitter-javascript":"^0.21.0",
    "tree-sitter-typescript": "^0.21.0"
  },
  "devDependencies": {
    "vitest": "^1.6.0"
  }
}
