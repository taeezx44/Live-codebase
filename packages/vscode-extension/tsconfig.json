{
  "compilerOptions": {
    "target":          "ES2020",
    "module":          "commonjs",
    "moduleResolution": "node",
    "lib":             ["ES2020"],
    "outDir":          "dist",
    "rootDir":         "src",
    "strict":          true,
    "declaration":     true,
    "sourceMap":       true,
    "skipLibCheck":    true,
    "noImplicitAny":   true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
